# ============================================
# Intelijen Keuangan (wa-finance) — .env
# by sanspriyatna
# ============================================

# --- LLM (OpenAI-compatible endpoint) ---
# OpenAI:  https://api.openai.com/v1
# Groq:    https://api.groq.com/openai/v1
# Gemini:  https://generativelanguage.googleapis.com/v1beta/openai
# Ollama:  http://localhost:11434/v1
LLM_API_KEY=sk-your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# --- Google Sheets ---
# Opsi 1 (direkomendasikan untuk VPS/on-premise):
#   Simpan file JSON ke server, isi path-nya di sini.
GOOGLE_APPLICATION_CREDENTIALS=./data/google/service-account.json

# Opsi 2 (alternatif — isi konten JSON langsung sebagai string satu baris):
#   Gunakan jika tidak bisa upload file (contoh: env var di control panel hosting).
#   Kosongkan jika sudah mengisi GOOGLE_APPLICATION_CREDENTIALS.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Spreadsheet ID dari URL:
# https://docs.google.com/spreadsheets/d/<ID_INI>/edit
SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# --- WhatsApp Session Store (SQLite) ---
# Path file SQLite untuk menyimpan session WhatsApp.
# Pastikan folder induknya ada (mkdir -p data/whatsapp).
WHATSAPP_SESSION_DB_PATH=./data/whatsapp/session.db

# --- Owner Whitelist ---
# Nomor HP yang diizinkan berkomunikasi dengan bot.
# Format: kode negara + nomor tanpa "+" atau spasi.
# Contoh: 0812-3456-7890 (Indonesia) → 6281234567890
# Bisa lebih dari satu, pisahkan dengan koma: 6281111111111,6282222222222
OWNER_PHONE_NUMBER=6281234567890

# --- Group Chat (Opsional) ---
# Kosongkan jika bot hanya untuk DM personal.
# Isi dengan JID group (bagian sebelum @g.us) jika ingin bot aktif di grup.
# Cara cari: kirim pesan di grup → lihat log bot → "JID: 120363XXXXXXXXX"
# Bisa lebih dari satu, pisahkan koma: 120363AAA,120363BBB
ALLOWED_GROUP_JIDS=
